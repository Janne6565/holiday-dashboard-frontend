{
  "openapi": "3.1.0",
  "info": {
    "title": "OpenAPI definition",
    "version": "v0"
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Generated server url"
    }
  ],
  "tags": [
    {
      "name": "Chore",
      "description": "Recurring chores (Routine) with overdue detection"
    },
    {
      "name": "Board",
      "description": "The whole shared dashboard state in one payload"
    },
    {
      "name": "Shopping",
      "description": "Shared shopping list (Einkauf)"
    },
    {
      "name": "Todo",
      "description": "Kanban task board"
    },
    {
      "name": "Metrics ingest",
      "description": "Claude usage push endpoint (guarded by the X-Ingest-Key header)"
    },
    {
      "name": "League of Legends",
      "description": "Live match data from the Riot API"
    },
    {
      "name": "Working status",
      "description": "\"X arbeitet gerade an …\" per person"
    }
  ],
  "paths": {
    "/api/v1/status/{person}": {
      "put": {
        "tags": ["Working status"],
        "summary": "Update one resident's working status",
        "operationId": "updateStatus",
        "parameters": [
          {
            "name": "person",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": ["janne", "simon"]
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WorkingStatusUpdateDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/WorkingStatusDto"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/shopping/{id}/toggle": {
      "put": {
        "tags": ["Shopping"],
        "summary": "Toggle an item's done state",
        "operationId": "toggleItem",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ShoppingItemDto"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/chores/{id}/interval": {
      "put": {
        "tags": ["Chore"],
        "summary": "Change a chore's interval",
        "operationId": "updateInterval",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChoreIntervalUpdateDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ChoreDto"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/chores/{id}/done": {
      "put": {
        "tags": ["Chore"],
        "summary": "Mark a chore as done now (resets the timer)",
        "operationId": "markDone",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ChoreDto"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/todos": {
      "get": {
        "tags": ["Todo"],
        "summary": "List all tasks",
        "operationId": "listTodos",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TodoDto"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Todo"],
        "summary": "Create a task (starts in the 'todo' column)",
        "operationId": "createTodo",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TodoCreationDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/TodoDto"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/shopping": {
      "get": {
        "tags": ["Shopping"],
        "summary": "List all shopping items",
        "operationId": "listItems",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ShoppingItemDto"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Shopping"],
        "summary": "Add a shopping item",
        "operationId": "addItem",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ShoppingItemCreationDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ShoppingItemDto"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/metrics/tokens/{person}": {
      "post": {
        "tags": ["Metrics ingest"],
        "summary": "Upsert the latest Claude usage snapshot for one person",
        "operationId": "ingestTokens",
        "parameters": [
          {
            "name": "person",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": ["janne", "simon"]
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TokenUsageIngestDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/TokenUsageDto"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/chores": {
      "get": {
        "tags": ["Chore"],
        "summary": "List all chores with derived overdue state",
        "operationId": "listChores",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ChoreDto"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Chore"],
        "summary": "Create a recurring chore (marks it done now)",
        "operationId": "createChore",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChoreCreationDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ChoreDto"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/todos/{id}": {
      "delete": {
        "tags": ["Todo"],
        "summary": "Delete a task",
        "operationId": "deleteTodo",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "patch": {
        "tags": ["Todo"],
        "summary": "Update a task (title / category / status / priority)",
        "operationId": "updateTodo",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TodoUpdateDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/TodoDto"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/status": {
      "get": {
        "tags": ["Working status"],
        "summary": "Get both residents' current working status",
        "operationId": "getStatus",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/WorkingStatusDto"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/lol": {
      "get": {
        "tags": ["League of Legends"],
        "summary": "Today's win/loss tally and recent matches",
        "operationId": "getLol",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/LolSummaryDto"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/board": {
      "get": {
        "tags": ["Board"],
        "summary": "Get the full dashboard aggregate (tasks, shopping, chores, status, tokens, LoL)",
        "operationId": "getBoard",
        "responses": {
          "200": {
            "description": "Board returned",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BoardDto"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/shopping/{id}": {
      "delete": {
        "tags": ["Shopping"],
        "summary": "Delete a shopping item",
        "operationId": "deleteItem",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/v1/shopping/done": {
      "delete": {
        "tags": ["Shopping"],
        "summary": "Remove all done items",
        "operationId": "clearDone",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/v1/chores/{id}": {
      "delete": {
        "tags": ["Chore"],
        "summary": "Delete a chore",
        "operationId": "deleteChore",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "WorkingStatusUpdateDto": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "maxLength": 300,
            "minLength": 0
          }
        }
      },
      "WorkingStatusDto": {
        "type": "object",
        "properties": {
          "janne": {
            "type": "string"
          },
          "simon": {
            "type": "string"
          }
        }
      },
      "ShoppingItemDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "done": {
            "type": "boolean"
          }
        }
      },
      "ChoreIntervalUpdateDto": {
        "type": "object",
        "properties": {
          "intervalHours": {
            "type": "integer",
            "format": "int32",
            "maximum": 8760,
            "minimum": 1
          }
        }
      },
      "ChoreDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "lastDone": {
            "type": "string",
            "format": "date-time"
          },
          "intervalHours": {
            "type": "integer",
            "format": "int32"
          },
          "hoursSinceLastDone": {
            "type": "integer",
            "format": "int64"
          },
          "overdue": {
            "type": "boolean"
          }
        }
      },
      "TodoCreationDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "maxLength": 200,
            "minLength": 0
          },
          "cat": {
            "type": "string",
            "enum": ["tech", "freizeit"]
          },
          "prio": {
            "type": "string",
            "enum": ["hoch", "mittel", "niedrig"]
          }
        },
        "required": ["cat", "prio", "title"]
      },
      "TodoDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "cat": {
            "type": "string",
            "enum": ["tech", "freizeit"]
          },
          "status": {
            "type": "string",
            "enum": ["todo", "doing", "done"]
          },
          "prio": {
            "type": "string",
            "enum": ["hoch", "mittel", "niedrig"]
          }
        }
      },
      "ShoppingItemCreationDto": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "maxLength": 200,
            "minLength": 0
          }
        },
        "required": ["text"]
      },
      "TokenUsageIngestDto": {
        "type": "object",
        "properties": {
          "fiveHPct": {
            "type": "integer",
            "format": "int32",
            "maximum": 100,
            "minimum": 0
          },
          "fiveHResetMin": {
            "type": "integer",
            "format": "int32"
          },
          "weekPct": {
            "type": "integer",
            "format": "int32",
            "maximum": 100,
            "minimum": 0
          },
          "costEur": {
            "type": "number",
            "format": "double"
          },
          "history": {
            "type": "array",
            "items": {
              "type": "number",
              "format": "double"
            },
            "maxItems": 31,
            "minItems": 0
          }
        },
        "required": ["history"]
      },
      "TokenUsageDto": {
        "type": "object",
        "properties": {
          "fiveHPct": {
            "type": "integer",
            "format": "int32"
          },
          "fiveHResetMin": {
            "type": "integer",
            "format": "int32"
          },
          "weekPct": {
            "type": "integer",
            "format": "int32"
          },
          "costEur": {
            "type": "number",
            "format": "double"
          },
          "history": {
            "type": "array",
            "items": {
              "type": "number",
              "format": "double"
            }
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ChoreCreationDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "maxLength": 200,
            "minLength": 0
          },
          "intervalHours": {
            "type": "integer",
            "format": "int32",
            "maximum": 8760,
            "minimum": 1
          }
        },
        "required": ["title"]
      },
      "TodoUpdateDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "maxLength": 200,
            "minLength": 0
          },
          "cat": {
            "type": "string",
            "enum": ["tech", "freizeit"]
          },
          "status": {
            "type": "string",
            "enum": ["todo", "doing", "done"]
          },
          "prio": {
            "type": "string",
            "enum": ["hoch", "mittel", "niedrig"]
          }
        }
      },
      "LolMatchDto": {
        "type": "object",
        "properties": {
          "players": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LolPlayerDto"
            }
          },
          "win": {
            "type": "boolean"
          },
          "mode": {
            "type": "string"
          },
          "playedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "LolPlayerDto": {
        "type": "object",
        "properties": {
          "champ": {
            "type": "string"
          },
          "who": {
            "type": "string"
          },
          "kda": {
            "type": "string"
          }
        }
      },
      "LolSummaryDto": {
        "type": "object",
        "properties": {
          "todayWins": {
            "type": "integer",
            "format": "int32"
          },
          "todayLosses": {
            "type": "integer",
            "format": "int32"
          },
          "matches": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LolMatchDto"
            }
          }
        }
      },
      "BoardDto": {
        "type": "object",
        "properties": {
          "todos": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TodoDto"
            }
          },
          "shopping": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ShoppingItemDto"
            }
          },
          "chores": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ChoreDto"
            }
          },
          "working": {
            "$ref": "#/components/schemas/WorkingStatusDto"
          },
          "tokens": {
            "$ref": "#/components/schemas/TokensDto"
          },
          "lol": {
            "$ref": "#/components/schemas/LolSummaryDto"
          }
        }
      },
      "TokensDto": {
        "type": "object",
        "properties": {
          "janne": {
            "$ref": "#/components/schemas/TokenUsageDto"
          },
          "simon": {
            "$ref": "#/components/schemas/TokenUsageDto"
          }
        }
      }
    }
  }
}
